---
const links = [
  { label: 'Email',     href: 'mailto:your@email.com',                      value: 'your@email.com' },
  { label: 'GitHub',    href: 'https://github.com/pstong216',                value: 'github.com/pstong216' },
  { label: 'LinkedIn',  href: 'https://linkedin.com/in/yourhandle',          value: 'linkedin.com/in/yourhandle' },
  { label: 'Scholar',   href: 'https://scholar.google.com/citations?user=', value: 'Google Scholar' },
];
---

<section id="contact">
  <div class="container">
    <div class="section-header reveal">
      <span class="label">04</span>
      <h2>Contact</h2>
    </div>

    <div class="contact-body">
      <p class="contact-intro reveal reveal-delay-1">
        I'm always open to interesting conversations, collaborations, and questions.
        The best way to reach me is by email.
      </p>

      <ul class="contact-links reveal reveal-delay-2">
        {links.map(l => (
          <li>
            <dt class="label">{l.label}</dt>
            <dd>
              <a href={l.href} class="contact-link" target={l.href.startsWith('http') ? '_blank' : undefined} rel="noopener">
                {l.value}
              </a>
            </dd>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .contact-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-intro {
    font-family: var(--f-display);
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.55;
    color: var(--fg);
    max-width: 36ch;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-links li {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .contact-link {
    font-size: 0.95rem;
    color: var(--fg);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.15rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .contact-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 720px) {
    .contact-body {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
