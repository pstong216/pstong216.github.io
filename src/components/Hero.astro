---
interface NewsItem {
  date: string;
  content?: string;
  prefix?: string;
  linkText?: string;
  suffix?: string;
  url?: string;
}

const news: NewsItem[] = [
  {
    date: '2026-04',
    content: 'One paper to appear in FAccT 2026',
  },
  {
    date: '2026-01',
    linkText: 'TrajectoryCurer',
    suffix: ' to appear in PacificVis 2026',
    url: 'https://dwe.ng/pdf/trajcurer.pdf',
  },
  {
    date: '2025-07',
    linkText: 'ReSpark',
    suffix: ' to appear in UIST 2025',
    url:'https://dl.acm.org/doi/pdf/10.1145/3746059.3747644'
  },
  {
    date: '2025-06',
    content: 'Graduated from Zhejiang University',
  },
  {
    date: '2025-01',
    linkText: 'TutorUp',
    suffix: ' to appear in CHI 2025 🌸',
    url:'https://dl.acm.org/doi/pdf/10.1145/3706598.3713589'
  },
];
---

<section id="hero" aria-label="Introduction">
  <div class="container hero-inner">
    <div class="hero-content">
      <img src="/me3.jpg" alt="Sitong Pan" class="hero-photo" />
      <div class="hero-text">
        <h1 class="display hero-name">Sitong Pan</h1>
        <div class="hero-meta">
          <p class="hero-role">Researcher &amp; <span class="accent">Generative AI</span></p>
          <p class="hero-affil">University of Minnesota &mdash; Minneapolis, MN</p>
        </div>
      </div>
    </div>

    <div class="hero-aside">
      <div class="hero-bio-text">
        <p>
          I am a PhD student in Computer Science advised by Professor Qianwen Wang in the University of Minnesota. Previously, I received my B.S. degree in Geography Information Science from Zhejiang University.
        </p>
        <p>
          My current research interest focues on Generative AI, including auto-regression based and diffusion-style models for text, image and viedo generation and understanding. 
        </p>
      </div>

      <dl class="hero-facts">
        <div class="hero-fact">
          <dt class="label">Links</dt>
          <dd>
            
            <a href="mailto:pstongboa@gmail.com" class="hero-link">Email</a>
            <span class="hero-link-sep">·</span>
            <a href="https://github.com/pstong216" class="hero-link" target="_blank" rel="noopener">GitHub</a>
            <span class="hero-link-sep">·</span>
            <a href="https://scholar.google.com/citations?user=hz-AickAAAAJ&hl" class="hero-link" target="_blank" rel="noopener">Scholar</a>
          </dd>
        </div>
      </dl>
    </div>

    <div class="hero-news">
      <p class="label hero-news-label">News</p>
      <ul class="hero-news-list">
        {news.map((item) => (
          <li class="hero-news-item">
            <span class="hero-news-date label">{item.date}</span>
            <p class="hero-news-content">
              {item.linkText
                ? <>{item.prefix}<a href={item.url} class="news-link" target="_blank" rel="noopener">{item.linkText}</a>{item.suffix}</>
                : item.content
              }
            </p>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="hero-year label" aria-hidden="true">2026</div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;1,400;1,600&display=swap');
  #hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: calc(var(--nav-h) + 1rem) clamp(3rem, 7vw, 6rem);
    border-top: none;
    position: relative;
    overflow: hidden;
  }

  /* Subtle background grid lines */
  #hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--border) 1px, transparent 1px),
      linear-gradient(to bottom, var(--border) 1px, transparent 1px);
    background-size: 80px 80px;
    opacity: 0.35;
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  .hero-news {
    grid-column: 1 / -1;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }

  .hero-news-label {
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .hero-news-list {
    display: flex;
    flex-direction: column;
  }

  .hero-news-item {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 2rem;
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--border);
    align-items: baseline;
  }

  .hero-news-item:first-child { border-top: 1px solid var(--border); }

  .hero-news-date { color: var(--muted); }

  .news-link {
    color: #217566;
    font-weight: 590;
    transition: opacity 0.2s;
  }
  .news-link:hover { opacity: 0.75; }

  .hero-news-content {
    font-family: 'Crimson Text', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--fg);
  }

  .hero-label {
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }

  .hero-content {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2rem;
  }

  .hero-photo {
    width: 240px;
    height: 300px;
    border-radius: 4px;
    object-fit: cover;
    object-position: center center;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
  }

  .hero-name-zh {
    font-family: var(--f-body);
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    margin-top: 0.2rem;
  }

  .hero-name {
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    color: var(--fg);
    opacity: 0;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.35s forwards;
  }

  .hero-meta {
    margin-top: 0.75rem;
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.5s forwards;
  }

  .hero-role {
    font-family: var(--f-display);
    font-size: 1.3rem;
    font-weight: 400;
    font-style: italic;
    color: var(--fg);
  }

  .accent { color: var(--accent); font-style: normal; }

  .hero-affil {
    font-family: var(--f-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-top: 0.4rem;
  }

  .hero-aside {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-bottom: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.65s forwards;
  }

  .hero-bio-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-bio-text p {
    font-family: 'Crimson Text', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
    font-weight: 400;
  }

  .hero-facts {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .hero-fact {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .hero-fact dd {
    font-size: 0.92rem;
    color: var(--fg);
  }

  .hero-link {
    font-family: 'Crimson Text', Georgia, serif;
    color: var(--fg);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.1rem;
    transition: color 0.2s, border-color 0.2s;
    font-size: 1.05rem;
  }

  .hero-link:hover { color: var(--accent); border-color: var(--accent); }

  .hero-link-sep {
    color: var(--border);
    margin-inline: 0.4rem;
    font-size: 0.8rem;
  }

  .hero-year {
    position: absolute;
    bottom: clamp(3rem, 7vw, 6rem);
    right: var(--pad-x);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.2em;
    writing-mode: vertical-rl;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 760px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-content { flex-direction: column; align-items: flex-start; }
    .hero-name { font-size: clamp(2.5rem, 10vw, 4rem); }
    .hero-year { display: none; }
  }
</style>
