---
interface Item {
  category: string;
  content: string[];
}

const items: Item[] = [
  {
    category: 'Currently Reading',
    content: ['《Love in a Fallen City》 Eileen Chang'],
  },
  {
    category: 'Listening To',
    content: ['Jacob Collier - Djesse Vol.4', 'Fox Stevenson - Sunk Cost Fallacy'],
  },
  {
    category: 'Side Project',
    content: ['Multimodal Model Steering', 'Fine-tuning for Diffusion Language Models'],
  },
  {
    category: 'Hobby',
    content: ['Electronic Guitar and Bass', 'Bouldering', 'Minecraft'],
  },
  {
    category: 'Fun Fact',
    content: ['A lot of my bouldering friends are twins and so am I'],
  },
  {
    category: 'Currently Learning',
    content: ['JEPA series from Yann LeCun'],
  },
];
---

<section id="misc">
  <div class="container">
    <div class="section-header reveal">
      <span class="label">05</span>
      <h2>Misc</h2>
    </div>

    <p class="misc-intro reveal reveal-delay-1">
      
    </p>

    <ul class="misc-grid">
      {items.map((item, i) => (
        <li class={`misc-card reveal reveal-delay-${Math.min((i % 3) + 1, 4)}`}>
          <dt class="label misc-cat">{item.category}</dt>
          <dd class="misc-content">
            {item.content.map((line, j) => (
              <>
                {line}
                {j < item.content.length - 1 && <br />}
              </>
            ))}
          </dd>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;1,400;1,600&display=swap');
  .misc-intro {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 50ch;
  }

  .misc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .misc-card {
    background: var(--bg);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background 0.25s ease;
  }

  .misc-card:hover { background: var(--surface); }

  .misc-cat {
    color: var(--accent);
  }

  .misc-content {
    font-family: 'Crimson Text', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--fg);
  }

  @media (max-width: 820px) {
    .misc-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 520px) {
    .misc-grid { grid-template-columns: 1fr; }
  }
</style>
